{
  "name": "fmg-lib",
  "version": "0.1.0-preview.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "parity:oracle": "bun ./scripts/fetch-upstream-oracle.ts --output artifacts/parity/upstream-oracle.json",
    "parity:refresh": "bun ./scripts/check-parity.ts --refresh true",
    "parity:check": "bun ./scripts/check-parity.ts",
    "parity:terrain": "bun ./scripts/check-terrain-parity.ts",
    "parity:physical": "bun ./scripts/check-physical-parity.ts",
    "parity:downstream": "bun ./scripts/check-downstream-parity.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test ./tests",
    "check": "bun run typecheck && bun test ./tests",
    "guardrails": "bun ./scripts/check-ui-guardrails.mjs",
    "check:ui-guardrails": "bun ./scripts/check-ui-guardrails.mjs",
    "check:ui": "bun run guardrails && bun run --cwd ui check",
    "check:all": "bun run check && bun run check:ui",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "perf:baseline": "bun run ./scripts/perf-baseline.ts",
    "release:check": "bun run check && bun run parity:check",
    "ui:install": "bun install",
    "ui:dev": "bun run --cwd ui dev",
    "ui:build": "bun run --cwd ui build",
    "ui:typecheck": "bun run --cwd ui typecheck",
    "ui:test": "bun run --cwd ui test",
    "ui:perf": "bun run --cwd ui perf:baseline",
    "screenshot:install-browser": "bunx playwright install firefox",
    "screenshot:milestone": "bun ./scripts/capture-milestone-screenshot.mjs",
    "screenshot:drift": "bun ./scripts/check-screenshot-drift.mjs",
    "parity:render": "bun run ui:build && bun ./scripts/check-render-parity.mjs",
    "screenshot:milestone:ui-shell": "bun run ui:build && bun ./scripts/capture-milestone-screenshot.mjs --slug m01-ui-shell-local --static-root ui/dist --static-path / --selector [data-screenshot=\"ui-shell\"] --ready-selector [data-screenshot=\"ui-shell-canvas\"] --delay-ms 1000",
    "screenshot:dummy": "bun ./scripts/capture-milestone-screenshot.mjs --slug ui-dummy-current",
    "screenshot:dummy:drift": "bun ./scripts/check-screenshot-drift.mjs --slug ui-dummy-current --baseline ./screenshots/ui-dummy-step-01.png --note \"Upstream UI shell is not stable yet, so this drift check compares against the approved local dummy baseline.\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/cli": "^0.1.1",
    "@types/d3-delaunay": "^6.0.4",
    "bun-types": "latest",
    "playwright": "^1.58.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "d3-delaunay": "^6.0.4"
  }
}

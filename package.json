{
  "name": "fmg-lib",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test ./tests",
    "check": "bun run typecheck && bun test ./tests",
    "guardrails": "node ./scripts/check-ui-guardrails.mjs",
    "check:ui-guardrails": "node ./scripts/check-ui-guardrails.mjs",
    "check:ui": "bun run guardrails && npm --prefix ui run check",
    "check:all": "bun run check && bun run check:ui",
    "check:fixtures": "bun test ./tests/world-fixtures.integration.test.ts",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "perf:baseline": "bun run ./scripts/perf-baseline.ts",
    "release:check": "bun run check && bun run check:fixtures",
    "ui:install": "npm --prefix ui install",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "ui:typecheck": "npm --prefix ui run typecheck",
    "ui:test": "npm --prefix ui run test",
    "ui:perf": "npm --prefix ui run perf:baseline",
    "screenshot:install-browser": "npm exec playwright -- install firefox",
    "screenshot:milestone": "node ./scripts/capture-milestone-screenshot.mjs",
    "screenshot:drift": "node ./scripts/check-screenshot-drift.mjs",
    "screenshot:dummy": "node ./scripts/capture-milestone-screenshot.mjs --slug ui-dummy-current",
    "screenshot:dummy:drift": "node ./scripts/check-screenshot-drift.mjs --slug ui-dummy-current --baseline ./screenshots/ui-dummy-step-01.png --note \"Upstream UI shell is not stable yet, so this drift check compares against the approved local dummy baseline.\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/cli": "^0.1.1",
    "@types/d3-delaunay": "^6.0.4",
    "bun-types": "latest",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "d3-delaunay": "^6.0.4"
  }
}

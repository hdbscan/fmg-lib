{
  "name": "fmg-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4174",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "typecheck": "tsc --noEmit -p tsconfig.json",
